# Fichier .htaccess pour Laravel + Pages HTML statiques sur Hostinger
# À placer à la racine de /public_html/

# ============================================
# RÈGLES LARAVEL + HTML STATIQUE
# ============================================
<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Activer FollowSymLinks pour permettre les liens symboliques
    Options +FollowSymLinks

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # PRIORITÉ 1 : Si le fichier HTML existe directement, le servir (pages statiques)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteCond %{REQUEST_URI} \.html$ [NC]
    RewriteRule ^(.*)$ $1 [L]

    # PRIORITÉ 1b : Si le fichier HTML n'existe pas directement, chercher dans public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_URI} \.html$ [NC]
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ /public/$1 [L]

    # PRIORITÉ 1c : Servir les fichiers statiques (CSS, JS, images) depuis public/ si ils n'existent pas à la racine
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} \.(css|js|jpg|jpeg|png|gif|svg|webp|ico|woff|woff2|ttf|eot|mp4|webm)$ [NC]
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ /public/$1 [L]

    # PRIORITÉ 1d : Servir les fichiers du dossier media/ depuis public/media/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_URI} ^/media/ [NC]
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ /public/$1 [L]

    # PRIORITÉ 1e : Servir les fichiers storage/ depuis storage/app/public/ (SANS lien symbolique)
    # Solution pour Hostinger où symlink() est désactivé
    # Si le fichier est demandé via /storage/, le servir depuis storage/app/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_URI} ^/storage/(.*)$ [NC]
    RewriteCond %{DOCUMENT_ROOT}/storage/app/public/%1 -f
    RewriteRule ^storage/(.*)$ /storage/app/public/$1 [L]

    # Si le fichier existe dans public/storage/ (lien symbolique si créé manuellement), le servir
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_URI} ^/storage/ [NC]
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ /public/$1 [L]

    # PRIORITÉ 2 : Si c'est la racine (/) et que index.html existe dans public/, le servir
    RewriteCond %{REQUEST_URI} ^/$
    RewriteCond %{DOCUMENT_ROOT}/public/index.html -f
    RewriteRule ^$ /public/index.html [L]

    # PRIORITÉ 3 : Si c'est la racine (/) et que index.html existe directement, le servir
    RewriteCond %{REQUEST_URI} ^/$
    RewriteCond %{DOCUMENT_ROOT}/index.html -f
    RewriteRule ^$ /index.html [L]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # PRIORITÉ 4 : Send Requests To Front Controller (Laravel)...
    # Toutes les autres requêtes passent par Laravel
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# ============================================
# OPTIMISATIONS DE PERFORMANCE ET SEO
# ============================================

# Activer la compression GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml
</IfModule>

# Mise en cache des fichiers statiques
<IfModule mod_expires.c>
    ExpiresActive On

    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # CSS et JavaScript
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"

    # Polices
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"

    # Vidéos
    ExpiresByType video/mp4 "access plus 1 month"
    ExpiresByType video/webm "access plus 1 month"

    # HTML
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Headers de cache
<IfModule mod_headers.c>
    # Cache-Control pour les fichiers statiques
    <FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|ico|css|js|woff|woff2|ttf|eot)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>

    # Pas de cache pour les fichiers HTML
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # Sécurité
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Redirection HTTPS
<IfModule mod_rewrite.c>
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Protection des fichiers sensibles
<FilesMatch "^(\.htaccess|\.htpasswd|\.env|composer\.json|composer\.lock|package\.json|package-lock\.json)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Optimisation des performances
<IfModule mod_mime.c>
    # Types MIME corrects
    AddType image/svg+xml .svg
    AddType image/webp .webp
    AddType application/font-woff .woff
    AddType application/font-woff2 .woff2
</IfModule>

# Désactiver le listage des répertoires
Options -Indexes

